# Per-number proxy config
# Copy to proxies/<instance-name>.env, one per number
# Use DataImpulse sticky residential proxy with Morocco geo

# DataImpulse format: username__country-ma__session-UNIQUE_ID__sesstime-24h
# The session ID must be unique per number and NEVER change
# This keeps the same Morocco IP for this number forever

PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_PROTOCOL=http

# Sticky session — change "number-1" to match the instance name
# Each number gets a different session ID = different IP
PROXY_USERNAME=your_dataimpulse_username__country-ma__session-course-number-1__sesstime-24h
PROXY_PASSWORD=your_dataimpulse_password

# Optional: per-number webhook override
INSTANCE_WEBHOOK=