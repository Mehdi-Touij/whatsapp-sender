# Server
SERVER_URL=https://your-evolution-api.up.railway.app

# Evolution API auth key (generate with: openssl rand -hex 32)
GLOBAL_API_KEY=change-me-to-a-random-64-char-hex-string

# Database
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=evolution

# Webhook URL (your dashboard's webhook endpoint)
WEBHOOK_URL=https://your-dashboard.up.railway.app/api/webhook

# Trigger.dev
TRIGGER_SECRET=change-me-to-another-random-hex-string
TRIGGER_API_KEY=change-me-to-trigger-api-key